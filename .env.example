# Data source. Keep the real credential only in .env or a secret manager.
AI_INVENTORY_DATABASE_URL=postgresql+psycopg2://user:password@host:5432/database
AI_INVENTORY_USE_MOCK_DATA=true

# Optional OpenAI-compatible LLM enhancement.
AI_INVENTORY_LLM_ENABLED=false
AI_INVENTORY_LLM_API_KEY=
AI_INVENTORY_LLM_BASE_URL=https://api.deepseek.com
AI_INVENTORY_LLM_MODEL=deepseek-chat
AI_INVENTORY_LLM_TIMEOUT_SECONDS=60

# Frontend development configuration.
VITE_API_BASE_URL=http://127.0.0.1:8001/api
VITE_USE_MOCK_FALLBACK=false
